# ============================================================
# CRM CLÍNICO — Variables de entorno
# Copia este archivo como .env.local para desarrollo local
# En Railway/Vercel configura estas variables en el panel
# ============================================================

# --- Supabase ---
# Proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# --- JWT ---
# Genera una clave segura: openssl rand -base64 32
JWT_SECRET=cambia_esto_por_una_clave_segura_de_al_menos_32_caracteres

# --- URL de la app (para links en emails) ---
# Desarrollo:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Producción (cambia por tu dominio real):
# NEXT_PUBLIC_APP_URL=https://tu-app.railway.app

# --- Email de recuperación de contraseña (opcional) ---
# Regístrate gratis en resend.com y crea una API key
# Sin esto, el link de recuperación solo aparece en los logs del servidor
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
EMAIL_FROM=CRM Clinico <noreply@tudominio.com>
